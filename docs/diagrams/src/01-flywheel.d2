direction: right

classes: {
  git:      {style.fill: "#e3f2fd"; style.stroke: "#1565c0"; style.font-color: "#000"}
  argo:     {style.fill: "#fff8e1"; style.stroke: "#e65100"; style.font-color: "#000"}
  platform: {style.fill: "#eceff1"; style.stroke: "#546e7a"; style.font-color: "#000"}
  appteam:  {style.fill: "#e8f5e9"; style.stroke: "#2e7d32"; style.font-color: "#000"}
}

REPO: "openshift-gitops (git)" {
  style.fill: "#f8f9fa"
  GATES:   "clusters/{cluster}/{app}.yaml\n«gate files + overrides»" {class: git}
  SOURCES: "sources/{app}/\n«app configs»"                           {class: git}
  PROFILES:"profiles/\n«team + cluster-type defaults»"               {class: git}
}

TOOLS: "«tools cluster»" {
  style.fill: "#fffde7"
  APPSET: "«argo-appset»\napp-of-apps\n\nmatrix:\n  cluster list\n  × gate files" {class: argo}
  APPS:   "«argo-apps»\n{cluster}---{project}---{app}"               {class: argo}
}

TARGET: "«managed cluster»" {
  style.fill: "#f5f5f5"
  PLT: "«k8s objects»\nplatform configs" {class: platform}
  APP: "«k8s objects»\napp-team configs" {class: appteam}
}

REPO.GATES   -> TOOLS.APPSET: "gates which apps\nrun on which cluster"
TOOLS.APPSET -> TOOLS.APPS:   "generates one Application\nper gate file"
REPO.SOURCES -> TOOLS.APPS:   "app source content"
TOOLS.APPS   -> TARGET.PLT:   "continuously\nreconciles"
TOOLS.APPS   -> TARGET.APP:   "continuously\nreconciles"
